NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required in production. Use at least 32 random characters.
NURSING_SESSION_SECRET=replace-with-a-long-random-secret

# Used only by the explicit database seed command for QA accounts.
NURSING_TEST_ACCOUNT_PASSWORD=replace-before-seeding

# Required in production. Local development can use the isolated file-backed adapter.
DATABASE_URL=postgresql://doctarx_nursing:change-me@127.0.0.1:5432/doctarx_nursing
DB_POOL_MAX=10

# Optional and development-only. Never enable this in production.
NEXT_PUBLIC_ENABLE_NURSING_ROLE_SWITCHER=false
